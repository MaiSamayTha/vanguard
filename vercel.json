{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/home.html", "destination": "/home", "permanent": true },
    { "source": "/programs.html", "destination": "/programs", "permanent": true },
    { "source": "/academy.html", "destination": "/the-academy", "permanent": true },
    { "source": "/impact.html", "destination": "/our-impact", "permanent": true },
    { "source": "/leadership.html", "destination": "/the-leadership-team", "permanent": true },
    { "source": "/get-involved.html", "destination": "/get-involved", "permanent": true },
    { "source": "/apply.html", "destination": "/apply", "permanent": true },
    { "source": "/portal.html", "destination": "/portal", "permanent": true },
    { "source": "/Vanguard-legal.html", "destination": "/legal", "permanent": true },
    { "source": "/form-careers.html", "destination": "/form-careers", "permanent": true },
    { "source": "/form-consultation.html", "destination": "/form-consultation", "permanent": true },
    { "source": "/form-engineering-design.html", "destination": "/form-engineering-design", "permanent": true },
    { "source": "/form-executive-leadership.html", "destination": "/form-executive-leadership", "permanent": true },
    { "source": "/form-international-consulting.html", "destination": "/form-international-consulting", "permanent": true },
    { "source": "/formA.html", "destination": "/formA", "permanent": true },
    { "source": "/formB.html", "destination": "/formB", "permanent": true },
    { "source": "/get-involved-form.html", "destination": "/get-involved-form", "permanent": true },
    { "source": "/icp-registration.html", "destination": "/icp-registration", "permanent": true }
  ],
  "rewrites": [
    { "source": "/:page/assets/:path*", "destination": "/assets/:path*" },

    { "source": "/home", "destination": "/pages/home.html" },
    { "source": "/home/:section", "destination": "/pages/home.html" },
    { "source": "/programs", "destination": "/pages/programs.html" },
    { "source": "/programs/:section", "destination": "/pages/programs.html" },
    { "source": "/the-academy", "destination": "/pages/academy.html" },
    { "source": "/the-academy/:section", "destination": "/pages/academy.html" },
    { "source": "/our-impact", "destination": "/pages/impact.html" },
    { "source": "/our-impact/:section", "destination": "/pages/impact.html" },
    { "source": "/the-leadership-team", "destination": "/pages/leadership.html" },
    { "source": "/get-involved", "destination": "/pages/get-involved.html" },
    { "source": "/get-involved/:section", "destination": "/pages/get-involved.html" },
    { "source": "/apply", "destination": "/pages/apply.html" },
    { "source": "/portal", "destination": "/pages/portal.html" },
    { "source": "/legal", "destination": "/pages/legal.html" },

    { "source": "/form-careers", "destination": "/forms/careers.html" },
    { "source": "/form-consultation", "destination": "/forms/consultation.html" },
    { "source": "/form-engineering-design", "destination": "/forms/engineering-design.html" },
    { "source": "/form-executive-leadership", "destination": "/forms/executive-leadership.html" },
    { "source": "/form-international-consulting", "destination": "/forms/international-consulting.html" },
    { "source": "/formA", "destination": "/forms/premium-program-inquiry.html" },
    { "source": "/formB", "destination": "/forms/icp-consultation-request.html" },
    { "source": "/get-involved-form", "destination": "/forms/get-involved-inquiry.html" },
    { "source": "/icp-registration", "destination": "/forms/icp-registration.html" }
  ]
}
